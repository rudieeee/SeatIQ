# Flask
SECRET_KEY=replace-with-a-strong-random-secret
JWT_SECRET_KEY=replace-with-a-strong-random-jwt-secret

# MySQL (required)
# Format: mysql+pymysql://username:password@host:3306/database_name
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/seatiq

# Booking lifecycle
RESERVATION_TTL_MINUTES=15

# Optional one-time setup endpoint protection
ADMIN_SETUP_KEY=change-this-admin-key
